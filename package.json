{
  "name": "css-minify-tests",
  "version": "0.1.0",
  "type": "module",
  "description": "Correctness tests for CSS minifiers",
  "scripts": {
    "start": "http-server",
    "lint": "eslint *.js lib scripts",
    "fix": "npm run lint -- --fix",
    "test": "cross-env NO_COLOR=1 node ./run-tests.js",
    "test:debug": "cross-env DEBUG=true node ./run-tests.js",
    "new-test": "node ./scripts/create-test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@thejaredwilcurt/csslop": "^0.0.8",
    "clean-css": "^5.3.3",
    "cross-env": "^10.1.0",
    "csskit": "^0.0.26",
    "cssnano": "^8.0.2",
    "csso": "^5.0.5",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-tjw-base": "^5.0.0",
    "eslint-config-tjw-import-x": "^1.0.1",
    "eslint-config-tjw-jsdoc": "^2.0.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "globals": "^17.7.0",
    "http-server": "^14.1.1",
    "lightningcss": "^1.30.0",
    "marked": "^18.0.5",
    "postcss": "^8.5.16",
    "pretty-ms": "^9.3.0",
    "real-world-css-libraries": "^1.0.6",
    "sass": "^1.101.0",
    "shiki": "^4.3.0"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "unrs-resolver@1.12.2": true
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26.3.1"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.16.0"
    }
  }
}
